# Microchip XEC central DMA configuration options

# Copyright (c) 2026 Microchip Technology Inc.
# SPDX-License-Identifier: Apache-2.0

config DMA_MCHP_XEC
	bool "Microchip XEC series central DMA driver"
	default y
	depends on DT_HAS_MICROCHIP_XEC_DMAC_ENABLED
	help
	  DMA driver for Microchip XEC series MCUs.

if DMA_MCHP_XEC

XEC_DMA_NODE_PATH := $(dt_nodelabel_path,dmac)
XEC_DMA_MAX_CHANS := $(dt_node_int_prop_int,$(XEC_DMA_NODE_PATH),dma-channels)

config DMA_MCHP_XEC_DMAC_MAX_CHANNELS
	int "Microchip XEC central DMA maximum channels"
	default $(XEC_DMA_MAX_CHANS)
	help
	  The number of channels this instance of the Central DMA
	  controller supports.

config DMA_MCHP_XEC_MAX_BLOCKS_PER_CHAN
	int "Maximum DMA blocks per channel"
	default 1
	range 1 16
	help
	  Maximum number of dma_block_config entries the driver will
	  cache from a multi-block dma_config call. The XEC central DMA
	  hardware programs one block at a time; the driver chains the
	  remaining blocks in its ISR by ABORTing the channel, rewriting
	  MSA/MEA/DEVA from the cached block, and re-issuing RUN. Each
	  cached block costs roughly 16 bytes per channel.

	  Set this to 1 (the default) to preserve historical single-block
	  behavior bit-for-bit and the lowest RAM footprint. Increase it
	  when a peripheral driver needs ping-pong or scatter-style
	  transfers on the same START-to-STOP transaction (for example,
	  streaming target-mode RX in the I2Cv3-NL driver when the host
	  may write a payload larger than the per-instance receive
	  buffer).

endif #DMA_MCHP_XEC
